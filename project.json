                "value": 0.25,
                "min": 0.0,
                "max": 1.0,
                "step": 0.05
            },
            "colorsaturation": {
                "text": "Color Saturation",
                "type": "slider",
                "value": 0.9,
                "min": 0.0,
                "max": 1.0,
                "step": 0.1
            },
            "colorhueshift": {
                "text": "Color Hue Shift",
                "type": "slider",
                "value": 0.0,
                "min": 0.0,
                "max": 1.0,
                "step": 0.1
            },
            "backgroundcolor": {
                "text": "Background Color",
                "type": "color",
