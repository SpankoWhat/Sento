            "energysensitivity": {
                "text": "Energy Sensitivity",
                "type": "slider",
                "value": 1.0,
                "min": 0.3,
                "max": 3.0,
                "step": 0.1
            },
            "cameradistance": {
                "text": "Camera Distance",
                "type": "slider",
                "value": 22,
                "min": 8,
                "max": 50,
                "step": 1
            },
            "cameraheight": {
                "text": "Camera Height",
                "type": "slider",
                "value": 8,
                "min": 0,
                "max": 20,
                "step": 1
