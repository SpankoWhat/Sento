{
    "file": "index.html",
    "preview": "preview.jpg",
    "title": "Sento",
    "description": "Real-time 3D audio visualizer with classic and custom latent mappings, feature emphasis, and reactive color and glow controls.",
    "type": "web",
    "audioprocessing": true,
    "general": {
        "supportsaudioprocessing": true,
        "properties": {
            "traillength": {
                "text": "Trail Length",
                "type": "slider",
                "value": 600,
                "min": 100,
                "max": 1200,
                "step": 50
            },
            "spheresize": {
                "text": "Sphere Size",
                "type": "slider",
                "value": 1.0,
                "min": 0.2,
                "max": 3.0,
                "step": 0.2
            },
            "lineopacity": {
                "text": "Trail Line Opacity",
                "type": "slider",
                "value": 0.25,
                "min": 0.0,
                "max": 1.0,
                "step": 0.05
            },
            "colorsaturation": {
                "text": "Color Saturation",
                "type": "slider",
                "value": 0.9,
                "min": 0.0,
                "max": 1.0,
                "step": 0.1
            },
            "colormode": {
                "text": "Color Mode",
                "type": "combo",
                "value": "dynamic",
                "options": [
                    { "label": "Dynamic", "value": "dynamic" },
                    { "label": "Accent", "value": "accent" },
                    { "label": "Hybrid", "value": "hybrid" },
                    { "label": "Stereo", "value": "stereo" }
                ]
            },
            "colormix": {
                "text": "Accent Mix",
                "type": "slider",
                "value": 0.35,
                "min": 0.0,
                "max": 1.0,
                "step": 0.05,
                "condition": "colormode.value == 'hybrid'"
            },
            "colorhueshift": {
                "text": "Color Hue Shift",
                "type": "slider",
                "value": 0.0,
                "min": 0.0,
                "max": 1.0,
                "step": 0.1
            },
            "accentcolor": {
                "text": "Accent Color",
                "type": "color",
                "value": "0.20 0.72 1.0",
                "condition": "colormode.value == 'accent' || colormode.value == 'hybrid'"
            },
            "backgroundcolor": {
                "text": "Background Color",
                "type": "color",
                "value": "0.02 0.02 0.03"
            },
            "fogdensity": {
                "text": "Fog Density",
                "type": "slider",
                "value": 0.018,
                "min": 0.0,
